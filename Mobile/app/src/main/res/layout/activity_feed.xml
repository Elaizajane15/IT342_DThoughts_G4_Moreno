<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8EE">

    <!-- Main Content -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="32dp">

                <!-- Header with profile on left - X style -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:id="@+id/ivProfile"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/avatar_border"
                        android:padding="2dp"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your Feed"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#3D2600"
                            android:fontFamily="sans-serif"
                            android:includeFontPadding="false" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="What's on people's minds today"
                            android:textSize="12sp"
                            android:textColor="#7A6040"
                            android:fontFamily="sans-serif"
                            android:alpha="0.7" />
                    </LinearLayout>

                    <!-- Create Post Button -->
                    <ImageView
                        android:id="@+id/ivCreatePost"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_create"
                        android:padding="10dp"
                        android:background="@drawable/avatar_circle"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Daily Quote Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F5ECD4"
                    app:strokeColor="#EDE0C4"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✨ Daily Thought"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#C9A84C"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/tvDailyQuote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Every day is a new page in your story."
                            android:textSize="14sp"
                            android:textStyle="italic"
                            android:textColor="#3D2600"
                            android:lineSpacingExtra="4dp"
                            android:fontFamily="serif" />

                        <TextView
                            android:id="@+id/tvQuoteAuthor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— DailyThoughts"
                            android:textSize="11sp"
                            android:textColor="#7A6040"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Guest Banner (visible only in guest mode) -->
                <LinearLayout
                    android:id="@+id/guestBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F5ECD4"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="#FFF8EE"
                        android:layout_marginEnd="12dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔒"
                            android:textSize="22sp" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Viewing as Guest"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#3D2600" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign in to like, comment, and share your own thoughts."
                            android:textSize="12sp"
                            android:textColor="#7A6040" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGuestLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Login"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#3D2600"
                        app:backgroundTint="#E8C97A"
                        app:cornerRadius="50dp" />
                </LinearLayout>

                <!-- Compose Box (visible only for logged-in users) -->
                <LinearLayout
                    android:id="@+id/composeBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    android:elevation="2dp">

                    <TextView
                        android:id="@+id/tvComposeAvatar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="👤"
                        android:textSize="18sp"
                        android:background="@drawable/avatar_circle"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <EditText
                            android:id="@+id/etCompose"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="What's on your mind today?"
                            android:background="@null"
                            android:minHeight="50dp"
                            android:maxLines="3"
                            android:textSize="15sp"
                            android:textColor="#3D2600"
                            android:fontFamily="sans-serif" />

                        <LinearLayout
                            android:id="@+id/composeActions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:visibility="gone"
                            android:layout_marginTop="8dp"
                            android:paddingTop="8dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/btnAddMedia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📷 Add Image"
                                android:textSize="12sp"
                                android:padding="8dp"
                                android:background="?attr/selectableItemBackground"
                                android:textColor="#7A6040" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPostThought"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Post"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#3D2600"
                                app:backgroundTint="#E8C97A"
                                app:cornerRadius="50dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Tabs -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:background="#F5ECD4"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/tabForYou"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/tab_selected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:text="For You"
                        android:textColor="#3D2600"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tabFollowing"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/tab_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:text="Following"
                        android:textColor="#7A6040"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Error Banner -->
                <LinearLayout
                    android:id="@+id/bannerError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:id="@+id/tvErrorMsg"
                        android:text="Error loading posts"
                        android:textSize="13sp"
                        android:textColor="#3D2600" />

                    <Button
                        android:id="@+id/btnRetry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Retry"
                        android:textSize="11sp"
                        android:background="@android:color/transparent"
                        android:textColor="#7A6040" />
                </LinearLayout>

                <!-- Posts Container -->
                <LinearLayout
                    android:id="@+id/postsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Empty State -->
                <LinearLayout
                    android:id="@+id/emptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="60dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📓"
                        android:textSize="52sp"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvEmptyMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No thoughts yet. Be the first to share!"
                        android:textSize="14sp"
                        android:textColor="#7A6040"
                        android:textAlignment="center"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmptyAction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Share a Thought"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#3D2600"
                        app:backgroundTint="#E8C97A"
                        app:cornerRadius="50dp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- Loading Indicator -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="24dp"
                    android:visibility="gone" />

                <!-- Load More Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLoadMore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Load more thoughts ↓"
                    android:textSize="13sp"
                    android:textColor="#7A6040"
                    app:backgroundTint="@android:color/transparent"
                    app:strokeColor="#C9A84C"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="14dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.drawerlayout.widget.DrawerLayout>