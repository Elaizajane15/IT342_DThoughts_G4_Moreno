<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8EE">

    <!-- Main Content Container -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Main Content -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="56dp">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="32dp">

                    <!-- Header with profile on left -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/ivProfile"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/avatar_border"
                            android:padding="2dp"
                            android:layout_marginEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:scaleType="centerCrop"
                            app:shapeAppearanceOverlay="@style/CircleImageView"
                            android:src="@drawable/ic_profile_holder"
                            android:contentDescription="@string/desc_profile_picture" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/daily_thoughts_title"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#3D2600"
                                android:fontFamily="sans-serif-medium"
                                android:includeFontPadding="false" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/feed_subtitle_main"
                                android:textSize="12sp"
                                android:textColor="#7A6040"
                                android:fontFamily="sans-serif"
                                android:alpha="0.7" />
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.tabs.TabLayout
                        android:id="@+id/tabLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:background="@android:color/transparent"
                        app:tabIndicatorColor="#C9A84C"
                        app:tabIndicatorHeight="3dp"
                        app:tabSelectedTextColor="#3D2600"
                        app:tabTextAppearance="@style/TextAppearance.MaterialComponents.Subtitle2"
                        app:tabTextColor="#8B6B43">

                        <com.google.android.material.tabs.TabItem
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tab_for_you" />

                        <com.google.android.material.tabs.TabItem
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tab_following" />

                    </com.google.android.material.tabs.TabLayout>

                    <!-- Error Banner -->
                    <LinearLayout
                        android:id="@+id/bannerError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone"
                        android:elevation="2dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:id="@+id/tvErrorMsg"
                            android:text="@string/error_loading"
                            android:textSize="13sp"
                            android:textColor="#3D2600" />

                        <Button
                            android:id="@+id/btnRetry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/retry_label"
                            android:textSize="11sp"
                            android:background="@android:color/transparent"
                            android:textColor="#7A6040" />
                    </LinearLayout>

                    <!-- Posts Container -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvPosts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <!-- Empty State -->
                    <LinearLayout
                        android:id="@+id/emptyState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="60dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/journal_emoji"
                            android:textSize="52sp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:id="@+id/tvEmptyMessage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/empty_message"
                            android:textSize="14sp"
                            android:textColor="#7A6040"
                            android:textAlignment="center"
                            android:layout_marginBottom="16dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEmptyAction"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/share_thought_label"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#3D2600"
                            app:backgroundTint="#E8C97A"
                            app:cornerRadius="50dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- Loading Indicator -->
                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="24dp"
                        android:visibility="gone" />

                    <!-- Load More Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLoadMore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/load_more_label"
                        android:textSize="13sp"
                        android:textColor="#7A6040"
                        app:backgroundTint="@android:color/transparent"
                        app:strokeColor="#C9A84C"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="14dp"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- Standard Bottom Navigation Bar -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@color/white"
            app:menu="@menu/bottom_nav_menu"
            app:itemIconTint="@color/nav_icon_selector"
            app:itemTextColor="@color/nav_text_selector"
            app:labelVisibilityMode="labeled" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Sidebar / Drawer Content -->
    <include
        android:id="@+id/drawerProfile"
        layout="@layout/drawer_profile"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>