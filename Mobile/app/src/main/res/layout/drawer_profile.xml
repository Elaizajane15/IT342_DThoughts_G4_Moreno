<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF8EE"
    android:elevation="16dp">

    <!-- Header with Cover Image -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_cover">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingTop="48dp">

            <!-- Avatar -->
            <ImageView
                android:id="@+id/ivDrawerAvatar"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/avatar_border"
                android:padding="3dp"
                android:layout_marginBottom="12dp" />

            <!-- Name -->
            <TextView
                android:id="@+id/tvDrawerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#3D2600"
                android:layout_marginBottom="4dp" />

            <!-- Username -->
            <TextView
                android:id="@+id/tvDrawerUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@username"
                android:textSize="13sp"
                android:textColor="#7A6040"
                android:layout_marginBottom="12dp" />

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginEnd="16dp">

                    <TextView
                        android:id="@+id/tvFollowingCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="233"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#3D2600" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Following"
                        android:textSize="13sp"
                        android:textColor="#7A6040" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvFollowersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="139"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#3D2600" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Followers"
                        android:textSize="13sp"
                        android:textColor="#7A6040" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- Menu Items -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp">

            <!-- Profile Item -->
            <LinearLayout
                android:id="@+id/menuProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="👤"
                    android:textSize="18sp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Profile"
                    android:textSize="15sp"
                    android:textColor="#3D2600" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="18sp"
                    android:textColor="#7A6040" />
            </LinearLayout>

            <!-- Premium Item -->
            <LinearLayout
                android:id="@+id/menuPremium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="⭐"
                    android:textSize="18sp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Premium"
                    android:textSize="15sp"
                    android:textColor="#3D2600" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="18sp"
                    android:textColor="#7A6040" />
            </LinearLayout>

            <!-- Chat Item -->
            <LinearLayout
                android:id="@+id/menuChat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="💬"
                    android:textSize="18sp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Chat"
                    android:textSize="15sp"
                    android:textColor="#3D2600" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="18sp"
                    android:textColor="#7A6040" />
            </LinearLayout>

            <!-- Communities Item -->
            <LinearLayout
                android:id="@+id/menuCommunities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="👥"
                    android:textSize="18sp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Communities"
                    android:textSize="15sp"
                    android:textColor="#3D2600" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="18sp"
                    android:textColor="#7A6040" />
            </LinearLayout>

            <!-- Bookmarks Item -->
            <LinearLayout
                android:id="@+id/menuBookmarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="🔖"
                    android:textSize="18sp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bookmarks"
                    android:textSize="15sp"
                    android:textColor="#3D2600" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="18sp"
                    android:textColor="#7A6040" />
            </LinearLayout>

            <!-- Lists Item -->
            <LinearLayout
                android:id="@+id/menuLists"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="📋"
                    android:textSize="18sp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lists"
                    android:textSize="15sp"
                    android:textColor="#3D2600" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="18sp"
                    android:textColor="#7A6040" />
            </LinearLayout>

            <!-- Spaces Item -->
            <LinearLayout
                android:id="@+id/menuSpaces"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="🎧"
                    android:textSize="18sp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Spaces"
                    android:textSize="15sp"
                    android:textColor="#3D2600" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="18sp"
                    android:textColor="#7A6040" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EDE0C4"
                android:layout_marginVertical="8dp" />

            <!-- Download Grok -->
            <LinearLayout
                android:id="@+id/menuDownload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="📥"
                    android:textSize="18sp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Download Grok"
                    android:textSize="15sp"
                    android:textColor="#3D2600" />
            </LinearLayout>

            <!-- Settings and privacy -->
            <LinearLayout
                android:id="@+id/menuSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="⚙️"
                    android:textSize="18sp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Settings and privacy"
                    android:textSize="15sp"
                    android:textColor="#3D2600" />
            </LinearLayout>

            <!-- Help Center -->
            <LinearLayout
                android:id="@+id/menuHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="❓"
                    android:textSize="18sp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Help Center"
                    android:textSize="15sp"
                    android:textColor="#3D2600" />
            </LinearLayout>

            <!-- Divider before logout -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EDE0C4"
                android:layout_marginVertical="8dp" />

            <!-- Logout Button -->
            <LinearLayout
                android:id="@+id/menuLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="🚪"
                    android:textSize="18sp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Logout"
                    android:textSize="15sp"
                    android:textColor="#E74C3C"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>