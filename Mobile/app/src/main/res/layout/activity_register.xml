<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8EE"
    android:fillViewport="true"
    tools:context=".RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="40dp">

        <!-- ══ TOP BAR: Logo + Back ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_brand_icon"
                    android:layout_marginEnd="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/logo_emoji"
                        android:textSize="18sp"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/logo_part_1"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/muted"
                        android:fontFamily="serif"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/logo_part_2"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/amber_dark"
                        android:fontFamily="serif"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvBackLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_back_to_login"
                android:textSize="11sp"
                android:textColor="@color/muted"
                android:fontFamily="monospace"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <!-- ══ MAIN CARD ═════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_white"
            app:strokeColor="@color/border_amber"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Amber top accent line -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_amber_gradient_h"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- ── STEP INDICATORS ────────────────────── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Step 1 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <FrameLayout
                                android:id="@+id/step1Badge"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:layout_marginBottom="5dp"
                                android:background="@drawable/bg_step_active">

                                <TextView
                                    android:id="@+id/tvStep1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="@string/step_one"
                                    android:textColor="@color/muted"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.1"
                                android:text="@string/label_account"
                                android:textColor="@color/amber_dark"
                                android:textSize="@dimen/text_size_label" />
                        </LinearLayout>

                        <!-- Connector line -->
                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_marginBottom="18dp"
                            android:layout_weight="0.4"
                            android:background="@color/border_amber" />

                        <!-- Step 2 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <FrameLayout
                                android:id="@+id/step2Badge"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:layout_marginBottom="5dp"
                                android:background="@drawable/bg_step_inactive">

                                <TextView
                                    android:id="@+id/tvStep2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="2"
                                    android:textColor="@color/muted"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvStep2Label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.1"
                                android:text="@string/label_personal"
                                android:textColor="@color/muted_soft"
                                android:textSize="@dimen/text_size_label" />
                        </LinearLayout>

                        <!-- Connector line -->
                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_marginBottom="18dp"
                            android:layout_weight="0.4"
                            android:background="@color/border_amber" />

                        <!-- Step 3 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <FrameLayout
                                android:id="@+id/step3Badge"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:layout_marginBottom="5dp"
                                android:background="@drawable/bg_step_inactive">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="@string/step_three"
                                    android:textColor="@color/muted"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvStep3Label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.1"
                                android:text="@string/label_done"
                                android:textColor="@color/muted_soft"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- ── TITLE ──────────────────────────────── -->
                    <TextView
                        android:id="@+id/tvRegTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="serif"
                        android:text="@string/reg_title"
                        android:textColor="@color/muted"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvRegSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:text="@string/reg_subtitle"
                        android:textColor="@color/muted"
                        android:textSize="13sp" />

                    <!-- ── ERROR BANNER ────────────────────────── -->
                    <LinearLayout
                        android:id="@+id/bannerError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_error_banner"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/symbol_warning"
                            android:textColor="@color/rose_red"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvErrorMsg"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:textColor="@color/rose_red"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvErrorClose"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.5"
                            android:padding="4dp"
                            android:text="@string/close_icon"
                            android:textColor="@color/rose_red"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- ════════════════════════════════════════
                         STEP 0 CONTAINER — Email + Password
                         ════════════════════════════════════════ -->
                    <LinearLayout
                        android:id="@+id/step0Container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <!-- Email label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.15"
                            android:text="@string/label_email"
                            android:textColor="@color/muted"
                            android:textSize="@dimen/text_size_label"
                            android:textStyle="bold"/>

                        <!-- Email field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilEmail"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif"
                                android:hint="@string/hint_email_example"
                                android:inputType="textEmailAddress"
                                android:textColor="@color/ink"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Password label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.15"
                            android:text="@string/label_password"
                            android:textColor="@color/muted"
                            android:textSize="@dimen/text_size_label"
                            android:textStyle="bold"/>

                        <!-- Password field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilPassword"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:endIconMode="password_toggle"
                            app:endIconTint="@color/muted"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPassword"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_password_requirement"
                                android:inputType="textPassword"
                                android:textColor="@color/ink"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Password strength bar -->
                        <LinearLayout
                            android:id="@+id/strengthRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="5dp"
                                android:layout_marginBottom="5dp"
                                android:orientation="horizontal">

                                <View
                                    android:id="@+id/seg1"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_marginEnd="3dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_strength_seg" />

                                <View
                                    android:id="@+id/seg2"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_marginEnd="3dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_strength_seg" />

                                <View
                                    android:id="@+id/seg3"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_marginEnd="3dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_strength_seg" />

                                <View
                                    android:id="@+id/seg4"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_strength_seg" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tvStrengthLabel"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="monospace"
                                    android:text="@string/status_weak"
                                    android:textColor="@color/rose_red"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvCharCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="monospace"
                                    android:text="@string/char_count"
                                    android:textColor="@color/muted_soft"
                                    android:textSize="@dimen/text_size_label" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Confirm Password label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.15"
                            android:text="@string/label_confirm"
                            android:textColor="@color/muted"
                            android:textSize="@dimen/text_size_label"
                            android:textStyle="bold"
                            android:id="@+id/tvConfirmLabel"/>

                        <!-- Confirm Password field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilConfirm"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxStrokeColor="@color/border_amber"
                            app:endIconMode="password_toggle"
                            app:endIconTint="@color/muted"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etConfirm"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/label_re"
                                android:inputType="textPassword"
                                android:textColor="@color/ink"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:id="@+id/tvMatchIndicator"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            android:fontFamily="monospace"
                            android:text="@string/msg_password_match"
                            android:textColor="@color/success_green"
                            android:textSize="11sp"
                            android:visibility="gone" />

                        <!-- Continue button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnContinue"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:text="@string/btn_continue"
                            android:textColor="@color/ink"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/amber_dark"
                            app:cornerRadius="50dp" />

                    </LinearLayout>
                    <!-- end step0Container -->

                    <!-- ════════════════════════════════════════
                         STEP 1 CONTAINER — Name + Terms
                         ════════════════════════════════════════ -->
                    <LinearLayout
                        android:id="@+id/step1Container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!-- First + Last name row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:orientation="horizontal">

                            <!-- First Name -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="6dp"
                                    android:fontFamily="monospace"
                                    android:letterSpacing="0.15"
                                    android:text="@string/label_first_name"
                                    android:textColor="@color/muted"
                                    android:textSize="@dimen/text_size_label"
                                    android:textStyle="bold"/>

                                <com.google.android.material.textfield.TextInputLayout
                                    android:id="@+id/tilFirstName"
                                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    app:boxCornerRadiusBottomEnd="12dp"
                                    app:boxCornerRadiusBottomStart="12dp"
                                    app:boxCornerRadiusTopEnd="12dp"
                                    app:boxCornerRadiusTopStart="12dp"
                                    app:boxStrokeColor="@color/border_amber"
                                    app:hintEnabled="false">

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/etFirstName"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif"
                                        android:hint="@string/hint_first_name"
                                        android:inputType="textPersonName"
                                        android:textColor="@color/ink"
                                        android:textSize="14sp" />
                                </com.google.android.material.textfield.TextInputLayout>
                            </LinearLayout>

                            <!-- Last Name -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="6dp"
                                    android:fontFamily="monospace"
                                    android:letterSpacing="0.15"
                                    android:text="@string/label_last_name"
                                    android:textColor="@color/muted"
                                    android:textSize="@dimen/text_size_label"
                                    android:textStyle="bold"/>

                                <com.google.android.material.textfield.TextInputLayout
                                    android:id="@+id/tilLastName"
                                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    app:boxCornerRadiusBottomEnd="12dp"
                                    app:boxCornerRadiusBottomStart="12dp"
                                    app:boxCornerRadiusTopEnd="12dp"
                                    app:boxCornerRadiusTopStart="12dp"
                                    app:boxStrokeColor="@color/border_amber"
                                    app:hintEnabled="false">

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/etLastName"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif"
                                        android:hint="@string/hint_last_name"
                                        android:inputType="textPersonName"
                                        android:textColor="@color/ink"
                                        android:textSize="14sp" />
                                </com.google.android.material.textfield.TextInputLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Terms and conditions checkbox -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="22dp"
                            android:gravity="top"
                            android:orientation="horizontal">

                            <CheckBox
                                android:id="@+id/cbTerms"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:layout_marginEnd="10dp"
                                android:buttonTint="@color/amber_dark" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="I agree to the"
                                        android:textColor="@color/muted_soft"
                                        android:textSize="10sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text=" Terms of Service "
                                        android:textColor="@color/amber_dark"
                                        android:textSize="10sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="and"
                                        android:textColor="@color/muted_soft"
                                        android:textSize="10sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text=" Privacy Policy"
                                        android:textColor="@color/amber_dark"
                                        android:textSize="10sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Back + Create Account buttons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Back button -->
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnBack"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="50dp"
                                android:layout_marginEnd="10dp"
                                android:layout_weight="0.38"
                                android:text="@string/btn_back"
                                android:textColor="@color/muted"
                                android:textSize="13sp"
                                app:cornerRadius="50dp"
                                app:strokeColor="@color/border_amber" />

                            <!-- Create Account button -->
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnCreateAccount"
                                android:layout_width="0dp"
                                android:layout_height="50dp"
                                android:layout_weight="0.62"
                                android:text="@string/btn_create_account"
                                android:textColor="@color/ink"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                app:backgroundTint="@color/amber_dark"
                                app:cornerRadius="50dp" />
                        </LinearLayout>

                    </LinearLayout>
                    <!-- end step1Container -->

                    <!-- ── DIVIDER OR ─────────────────────────── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="@color/border_amber" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="@string/label_or_register"
                            android:textColor="@color/muted_soft"
                            android:textSize="@dimen/text_size_label" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="@color/border_amber" />
                    </LinearLayout>

                    <!-- ── GOOGLE BUTTON ───────────────────────── -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGoogle"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:text="@string/btn_google"
                        android:textColor="@color/mid"
                        android:textSize="13sp"
                        app:cornerRadius="50dp"
                        app:strokeColor="@color/border_amber"
                        android:drawableStart="@drawable/ic_google"
                        android:drawablePadding="10dp"/>

                    <!-- ── SIGN IN LINK ────────────────────────── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_already_account"
                            android:textColor="@color/muted_soft"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvGoLogin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="2dp"
                            android:text="@string/label_sign_in"
                            android:textColor="@color/amber_dark"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="4dp"/>
                    </LinearLayout>

                </LinearLayout>
                <!-- end inner padding layout -->

            </LinearLayout>
            <!-- end card vertical layout -->

        </com.google.android.material.card.MaterialCardView>
        <!-- end card -->

    </LinearLayout>
</ScrollView>
